# Número do WhatsApp com DDI, só dígitos (ex.: Brasil 55 + DDD + número)
# Copia o mesmo valor em Cloudflare Pages → Settings → Environment variables → Production → VITE_WHATSAPP_NUMBER
VITE_WHATSAPP_NUMBER=

# URL pública (produção): https://www.merkus.com.br — opcional para futuras features
# VITE_PUBLIC_SITE_URL=https://www.merkus.com.br

# Só para GitHub Pages em subpasta (ex.: /MEU-OVO/). Em Cloudflare Pages na raiz, deixe vazio ou não defina.
# VITE_BASE_PATH=/MEU-OVO/
